# Public site URL (SEO: sitemap, canonical, Open Graph)
NEXT_PUBLIC_SITE_URL=https://glansigbiltvatteskilstunaab.se

# ── Booking form → Glansbilvatt@gmail.com ───────────────────────────────────
# Add this in Vercel → Project → Settings → Environment Variables
# (same value for Production, Preview, Development)
#
# 1. https://web3forms.com → enter Glansbilvatt@gmail.com
# 2. Paste the access key:
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here
#
# Without this key, FormSubmit is used (first booking may need activation email).

# Optional server-side (Resend) — also add in Vercel env vars:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Glansbilvatt <bokning@glansbilvatt.se>
